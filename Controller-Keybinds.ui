  <property name="windowTitle"><string>KEYBINDS</string></property>
  <property name="styleSheet">
   <string notr="true">QDialog, QWidget {
    background-color: #0a0a0a;
    font-family: "Segoe UI", Arial, sans-serif;
    color: #e8e8e8;
}

QLabel {
    color: #44bd32; /* keep green text */
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1px;
    min-width: 80px;
}

QComboBox {
    background-color: #141414;
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    color: #ffffff;
    padding: 6px 10px;
    min-height: 30px;
    min-width: 100px;
}
QComboBox:hover { border: 1px solid #ffffff; }
QComboBox::drop-down { border: none; width: 28px; }
QComboBox::down-arrow { width: 0px; height: 0px; image: none; }

QScrollArea {
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    background-color: #141414;
}

QScrollBar:vertical {
    background: #141414;
    width: 8px;
    border-radius: 4px;
}
QScrollBar::handle:vertical {
    background: #ffffff;
    border-radius: 4px;
    min-height: 30px;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QPushButton {
    background-color: #141414;
    border: 2px solid #3a3a3a;
    border-radius: 10px;
    color: #ffffff;
    font-size: 14px;
    font-weight: 900;
    letter-spacing: 2px;
    padding: 10px 18px;
}
QPushButton:hover {
    background-color: #1a1a1a;
    border: 2px solid #ffffff;
}
QPushButton:pressed {
    background-color: #0a0a0a;
}

/* Title icon box */
QLabel#lblTitleIcon {
    min-width: 22px;
    max-width: 22px;
    min-height: 22px;
    max-height: 22px;
    background-color: transparent;
    border: none;
    image: url(icons/gamepad.svg);
}
</string>
