  <property name="styleSheet">
   <string notr="true">/* BLACK &amp; WHITE GAMING THEME - CORRECTED */

QMainWindow, QWidget {
    background-color: #0a0a0a;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: #e8e8e8;
}

QScrollBar:vertical {
    background: #141414;
    width: 8px;
    border-radius: 4px;
}

QScrollBar::handle:vertical {
    background: #ffffff;
    border-radius: 4px;
}

QGroupBox {
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    color: #ffffff;
    font-weight: 700;
    font-size: 15px;
    margin-top: 16px;
    padding: 14px 12px;
    background-color: #141414;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 16px;
    top: 0px;
    padding: 6px 10px;
    background-color: #ffffff;
    border-radius: 7px;
    color: #0C0C0C;
    font-size: 15px;
    font-weight: 900;
    letter-spacing: 2px;
    text-transform: uppercase;
}

QCheckBox {
    color: #e8e8e8;
    spacing: 10px;
    font-size: 13px;
    font-weight: 700;
    padding: 4px 0px;
    background-color: transparent;
}

QCheckBox:hover {
    color: #ffffff;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    background-color: transparent;
    border: 2px solid #3a3a3a;
}

QCheckBox::indicator:hover {
    border: 2px solid #ffffff;
}

QCheckBox::indicator:checked {
    background-color: transparent;
    border: 2px solid #ffffff;
    image: url(icons/check.svg);
}

QFrame[frameShape=&quot;4&quot;], QFrame[frameShape=&quot;5&quot;] {
    color: #2a2a2a;
    background-color: #2a2a2a;
}

QFrame[frameShape=&quot;4&quot;] {
    max-height: 1px;
    margin: 6px 0px;
}

QFrame[frameShape=&quot;5&quot;] {
    max-width: 1px;
    margin: 0px 8px;
}

QLabel {
    color: #e8e8e8;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
}

QProgressBar {
    background-color: #141414;
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    text-align: center;
    color: transparent;
    min-height: 26px;
    max-height: 26px;
}

QProgressBar::chunk {
    background-color: #ffffff;
    border-radius: 5px;
    margin: 1px;
}

QPushButton {
    background-color: #141414;
    border: 1px solid #3a3a3a;
    border-radius: 6px;
    color: #e8e8e8;
    padding: 6px 10px;
    font-size: 12px;
    font-weight: 700;
    min-width: 46px;
}

QPushButton:checked {
    background-color: #1a1a1a;
    border: 1px solid #ffffff;
    color: #ffffff;
    font-weight: 700;
}

QPushButton:hover {
    background-color: #1a1a1a;
    border: 1px solid #ffffff;
    color: #ffffff;
}

QLabel#lblFocus, QLabel#lblBlink, QLabel#lblJaw,
QLabel#lblEMG1, QLabel#lblEMG2, QLabel#lblEMG3, QLabel#lblEMG4, QLabel#lblECG {
    background-color: transparent;
}

QPushButton:pressed {
    background-color: #0a0a0a;
}

/* ── Disabled state ─────────────────────────────────────── */

QPushButton:disabled {
    background-color: #0d0d0d;
    border: 1px solid #1e1e1e;
    color: #333333;
}

QCheckBox:disabled {
    color: #333333;
}

QCheckBox::indicator:disabled {
    border: 2px solid #222222;
    background-color: transparent;
}

QLabel:disabled {
    color: #333333;
}</string>
